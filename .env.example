# Local environment for the seismic-graph project.
# This file is gitignored (.gitignore line 2) — safe to put secrets here.
#
# Load it into your shell with one of:
#   set -a; source .env; set +a            # bash / zsh
#   direnv allow                            # if you use direnv
#
# Anything Prefect / pandas reads from the environment goes here.

# --- Terraform: Neo4j Aura credentials ----------------------------------------
# `infra/main.tf` reads these via TF_VAR_* when the *_file paths are empty.
# TF_VAR_aura_client_id=
# TF_VAR_aura_client_secret=

# --- Prefect (optional) -------------------------------------------------------
# Point at Prefect Cloud or a self-hosted server. Leave unset to run locally.
# PREFECT_API_URL=
# PREFECT_API_KEY=

# --- Neo4j Aura ---------------------------------------------------------------
# `load/neo4j_loader.py` connects with these. Grab the URI / password from the
# Aura console when you create the instance.
# NEO4J_URI=neo4j+s://xxxxxxxx.databases.neo4j.io
# NEO4J_USER=neo4j
# NEO4J_PASSWORD=
